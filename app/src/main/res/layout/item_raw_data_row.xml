<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="8dp">

    <TextView
        android:id="@+id/tvRawTime"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.1"
        android:textSize="13sp"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:id="@+id/tvRawVoltage"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.6"
        android:textSize="13sp"
        android:gravity="end"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:id="@+id/tvRawCurrent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.6"
        android:textSize="13sp"
        android:gravity="end"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:id="@+id/tvRawPower"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.6"
        android:textSize="13sp"
        android:gravity="end"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:id="@+id/tvRawBattery"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.6"
        android:textSize="13sp"
        android:gravity="end"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:id="@+id/tvRawMaxPower"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1.1"
        android:textSize="13sp"
        android:gravity="end"
        android:textColor="?android:attr/textColorPrimary"/>

    <TextView
        android:id="@+id/tvRawScreenState"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.6"
        android:textSize="13sp"
        android:gravity="end"
        android:textColor="?android:attr/textColorPrimary"/>
</LinearLayout>
